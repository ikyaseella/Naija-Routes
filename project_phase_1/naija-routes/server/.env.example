# ────────────────────────────────────────────────
# NAIJA ROUTES — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# ── Supabase ─────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key-here

# Direct database connection (for migrations)
# Get from: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=postgresql://postgres:your-db-password@db.your-project-id.supabase.co:5432/postgres

# ── JWT ──────────────────────────────────────────
# Supabase manages JWT signing — you don't need to set this manually.
# Included here for reference only.
# JWT_SECRET=managed-by-supabase

# ── SMS (Activate in Phase 1) ─────────────────────
# Termii SMS — https://termii.com
# TERMII_API_KEY=your-termii-api-key
# TERMII_SENDER_ID=N-Routes

# ── Email (Activate in Phase 1) ───────────────────
# Resend transactional email — https://resend.com
# RESEND_API_KEY=re_your-resend-api-key

# ── Payment (Activate in Phase 2) ─────────────────
# Paystack — https://dashboard.paystack.com
# PAYSTACK_SECRET_KEY=sk_test_your-paystack-secret-key
# PAYSTACK_PUBLIC_KEY=pk_test_your-paystack-public-key
# PAYSTACK_WEBHOOK_SECRET=your-webhook-secret

# ── Storage (Activate in Phase 2) ─────────────────
# Cloudflare R2 — ticket PDFs, KYC documents
# R2_ACCOUNT_ID=your-cloudflare-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET_NAME=naija-routes-files

# ── Redis (Activate in Phase 2) ───────────────────
# Upstash serverless Redis — seat locking, session cache
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── CORS ─────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
